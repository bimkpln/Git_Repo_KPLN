<Window x:Class="KPLN_Tools.Forms.ApartmentExecutionReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPLN. Отчёт построения квартир"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White" Topmost="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Сохранить отчёт"
                    Width="150"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="SaveReport_Click"/>

            <Button Content="Закрыть"
                    Width="120"
                    Height="32"
                    Click="Close_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding HeaderText}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Показать"
                                                Width="86"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding CanNavigateToElement, Converter={StaticResource BoolToVis}}"
                                                Click="NavigateToElement_Click"/>

                                        <Button Content="Удалить остатки"
                                                Width="120"
                                                Height="28"
                                                Margin="0,0,6,0"
                                                Visibility="{Binding CanDeleteRemnants, Converter={StaticResource BoolToVis}}"
                                                Click="DeleteRemnants_Click"/>

                                        <Button Content="Вернуть 2D"
                                                Width="92"
                                                Height="28"
                                                Visibility="{Binding CanRestore2D, Converter={StaticResource BoolToVis}}"
                                                Click="Restore2DFamily_Click"/>
                                    </StackPanel>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Lines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="{Binding Foreground}"
                                                       FontSize="{Binding FontSize}"
                                                       FontWeight="{Binding FontWeight}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
