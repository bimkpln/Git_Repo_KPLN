<Window x:Class="KPLN_Tools.Forms.ApartmentPresetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPLN. Преднастройки квартиры"
        Height="620" Width="760" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="145"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="План" Grid.Row="0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Text="Открытый план:"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedPlan.PlanName}" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Стены" Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="10 10 10 5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Text="Зависимость снизу:"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{Binding LowerConstraintText}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Text="Зависимость сверху:"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="{Binding UpperConstraintText}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Смещение снизу:" FontWeight="Bold"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BaseOffsetText, UpdateSourceTrigger=PropertyChanged}" Height="22" Padding="1 2 2 2"
                             PreviewTextInput="DigitsOnly_PreviewTextInput" DataObject.Pasting="DigitsOnly_Pasting"/>
                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Неприсоединённая высота:" FontWeight="Bold"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding WallHeightText, UpdateSourceTrigger=PropertyChanged}" Height="22" Padding="1 2 2 2"
                             PreviewTextInput="DigitsOnly_PreviewTextInput" DataObject.Pasting="DigitsOnly_Pasting"/>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Header="Выбор типов" Grid.Row="4" >
            <Grid Margin="10 10 10 5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Assignments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Label}"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedValue}"/>
                                
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="120" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
            <Button Content="Отмена" Width="120" Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>