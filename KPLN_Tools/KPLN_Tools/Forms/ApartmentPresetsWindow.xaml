<Window x:Class="KPLN_Tools.Forms.ApartmentPresetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Преднастройки квартиры"
        Height="340" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Высота стен:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WallHeight, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Тип стен:"/>
        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding WallTypes}" SelectedItem="{Binding SelectedWallType}" />

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Входная дверь:"/>
        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding EntryDoors}" SelectedItem="{Binding SelectedEntryDoor}" />

        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="С/У двери:"/>
        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding BathroomDoors}" SelectedItem="{Binding SelectedBathroomDoor}" />

        <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Межкомнатные двери:"/>
        <ComboBox Grid.Row="8" Grid.Column="1" ItemsSource="{Binding RoomDoors}" SelectedItem="{Binding SelectedRoomDoor}" />

        <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Margin="0,0,8,0" Command="{Binding SaveCommand}" />
            <Button Content="Отмена" Width="100" Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>