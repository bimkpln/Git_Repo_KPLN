<Window x:Class="KPLN_Tools.Forms.ApartmentManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KPLN_Tools.Forms"
        Title="KPLN. Менеджер квартир"
        Width="1540" Height="700" ResizeMode="CanResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Century Gothic" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>

        <Style x:Key="FlatTileButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="#FF9A9A9A"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="0"/>

                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>

                            <Border x:Name="HoverOverlay"
                                    Background="#18FFFFFF"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Background" Value="#30FFFFFF"/>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FFE6F4FF"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="#FF8AC8F5" BorderThickness="1" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFD4ECFF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#FF5FB6F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFBFE4FF"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#FF3FA3E6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BottomActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="410"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ТИП КВАРТИР:" FontSize="24" FontWeight="SemiBold" Margin="8,8,8,4"/>
                        <ListBox ItemsSource="{Binding ApartmentTypes}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Name" FontSize="20" Margin="8"/>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="Black" BorderBrush="Black" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="{Binding SelectedType.Name}" VerticalAlignment="Center" Margin="12,0" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="Black" BorderThickness="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
                            <ItemsControl ItemsSource="{Binding SelectedType.Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="10" ItemWidth="250" ItemHeight="250"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="200" Height="200" Margin="5">
                                            <Button Style="{StaticResource FlatTileButtonStyle}"
                                                    Command="{Binding DataContext.PickItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="#FFEFEFEF">
                                                <Button.ToolTip>
                                                    <ToolTip Placement="Mouse" HasDropShadow="True" Visibility="{Binding Preview, Converter={StaticResource NullToVis}, ConverterParameter=NotNull}">
                                                        <Border Background="White" BorderBrush="Black" BorderThickness="1" Padding="6">
                                                            <Image Source="{Binding Preview}" Width="400" Height="400" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
                                                        </Border>
                                                    </ToolTip>
                                                </Button.ToolTip>

                                                <Grid ClipToBounds="True">
                                                    <Border Background="White" BorderBrush="Black" BorderThickness="1" Margin="1" Padding="1">
                                                        <Image Source="{Binding Preview}" Stretch="Uniform" StretchDirection="DownOnly" SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="Fant" Visibility="{Binding Preview, Converter={StaticResource NullToVis}, ConverterParameter=NotNull}"/>
                                                    </Border>

                                                    <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap"
                                                               Margin="8" Visibility="{Binding Preview, Converter={StaticResource NullToVis}}"/>
                                                </Grid>
                                            </Button>

                                            <Button Style="{StaticResource MiniIconButtonStyle}"
                                                    Visibility="{Binding DataContext.IsDep8, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,18,0" Command="{Binding DataContext.UploadImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" ToolTip="Загрузить/обновить изображение">
                                                <TextBlock Text="🖼" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource BottomActionButtonStyle}" Width="130" Content="Обновить БД" Margin="0" Visibility="{Binding IsDep8, Converter={StaticResource BoolToVis}}"
                        Command="{Binding UpdateDbCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource BottomActionButtonStyle}" Margin="0 15 10 0" Content="Обновить марки" Command="{Binding UpdateApartmentMarksCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Column="2" BorderBrush="Black" BorderThickness="2">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" Background="Black" Padding="12,9">
                    <TextBlock Text="ПРЕДНАСТРОЙКИ 3D" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </Border>

                <Button DockPanel.Dock="Top" Style="{StaticResource BottomActionButtonStyle}" Margin="12,12,12,4" Content="Обновить данные" Command="{Binding RefreshApartmentPresetsCommand}"/>

                <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,12">
                    <TextBlock Text="{Binding PresetsVm.StatusText}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="Действие для 2D-семейств после обработки:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox Height="28" Padding="8 5 2 2" ItemsSource="{Binding FamilyPostProcessActions}" SelectedItem="{Binding SelectedFamilyPostProcessAction}" DisplayMemberPath="Title"/>
                    <Button Style="{StaticResource BottomActionButtonStyle}" Margin="0,12,0,0" Content="Превратить в 3D" Command="{Binding ConvertTo3DCommand}"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <GroupBox Header="План" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <ComboBox ItemsSource="{Binding PresetsVm.Plans}" SelectedItem="{Binding PresetsVm.SelectedPlan}" DisplayMemberPath="PlanName"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Стены" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" FontWeight="Bold" Text="Зависимость снизу:"/>
                                    <TextBlock Grid.Column="2" Text="{Binding PresetsVm.LowerConstraintText}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" FontWeight="Bold" Text="Зависимость сверху:"/>
                                    <TextBlock Grid.Column="2" Text="{Binding PresetsVm.UpperConstraintText}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Смещение снизу:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Text="{Binding PresetsVm.BaseOffsetText, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="3"
                                             PreviewTextInput="DigitsOnly_PreviewTextInput" DataObject.Pasting="DigitsOnly_Pasting"/>
                                </Grid>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Неприсоединённая высота:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Text="{Binding PresetsVm.WallHeightText, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="3"
                                             PreviewTextInput="DigitsOnly_PreviewTextInput" DataObject.Pasting="DigitsOnly_Pasting"/>
                                </Grid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Типы стен" Margin="0,0,0,10">
                            <ItemsControl ItemsSource="{Binding PresetsVm.WallAssignments}" Margin="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" Text="{Binding Label}" TextWrapping="Wrap"/>
                                            <ComboBox Grid.Row="2" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedValue}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <GroupBox Header="Стены (Шахта)" Margin="0,0,0,10"
                                  Visibility="{Binding PresetsVm.HasShaftWallMarkers, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Тип стены:" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" ItemsSource="{Binding PresetsVm.ShaftWallTypeOptions}" SelectedItem="{Binding PresetsVm.SelectedShaftWallType}"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Окна" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Тип окна:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding PresetsVm.WindowTypeOptions}" SelectedItem="{Binding PresetsVm.SelectedWindowType}"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Высота нижнего бруса:" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="2" Text="{Binding PresetsVm.WindowSillHeightText, UpdateSourceTrigger=PropertyChanged}" Height="24" Padding="3"
                                             PreviewTextInput="DigitsOnly_PreviewTextInput" DataObject.Pasting="DigitsOnly_Pasting"/>
                                </Grid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Двери">
                            <ItemsControl ItemsSource="{Binding PresetsVm.DoorAssignments}" Margin="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="4"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" FontWeight="Bold" Text="{Binding Label}" TextWrapping="Wrap"/>
                                            <ComboBox Grid.Row="2" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedValue}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>