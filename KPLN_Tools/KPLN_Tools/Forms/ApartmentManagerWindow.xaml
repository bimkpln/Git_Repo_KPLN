<Window x:Class="KPLN_Tools.Forms.ApartmentManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KPLN_Tools.Forms"
        Title="KPLN. Менеджер квартир"
        Width="980" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Century Gothic">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <Style x:Key="FlatTileButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Background" Value="#FF9A9A9A"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="0"/>
                            <ContentPresenter x:Name="Cp" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            <Border x:Name="HoverOverlay" Background="#33FFFFFF" Opacity="0" IsHitTestVisible="False"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Background" Value="#55FFFFFF"/>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MiniIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#CCFFFFFF"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFEAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ТИП КВАРТИР:" FontSize="24" FontWeight="SemiBold" Margin="8,8,8,4"/>
                    <ListBox ItemsSource="{Binding ApartmentTypes}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Name" FontSize="20" Margin="8"/>
                </DockPanel>
            </Border>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="Black" BorderBrush="Black" BorderThickness="1">
                    <Grid>
                        <TextBlock Text="{Binding SelectedType.Name}" VerticalAlignment="Center" Margin="12,0" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" BorderBrush="Black" BorderThickness="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SelectedType.Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="10" ItemWidth="160" ItemHeight="160"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="150" Height="150" Margin="10">
                                        <Button Style="{StaticResource FlatTileButtonStyle}" Command="{Binding DataContext.PickItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                            <Grid>
                                                <Image Source="{Binding Preview}" Stretch="UniformToFill" SnapsToDevicePixels="True" Visibility="{Binding Preview, Converter={StaticResource NullToVis}, ConverterParameter=NotNull}"/>
                                                <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" 
                                                           Visibility="{Binding Preview, Converter={StaticResource NullToVis}}"/>
                                            </Grid>
                                        </Button>
                                        <Button Style="{StaticResource MiniIconButtonStyle}" Visibility="{Binding DataContext.IsDep8, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5.3,15,0" Command="{Binding DataContext.UploadImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" ToolTip="Загрузить/обновить изображение">
                                            <TextBlock Text="🖼" FontSize="13"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Button Visibility="{Binding IsDep8, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="130" Height="36" BorderThickness="2" FontWeight="SemiBold" 
                    Content="↻ Обновить БД" Command="{Binding RefreshDbCommand}"/>
        </Grid>
    </Grid>
</Window>