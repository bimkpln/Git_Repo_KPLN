<Window x:Class="KPLN_Tools.Forms.HiddenElementsFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPLN. Управление скрытыми элементами"
        Height="590"
        Width="1040"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="SheetsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Лист" Binding="{Binding SheetDisplayName}" Width="*"/>
                <DataGridTextColumn Header="Планов всего" Binding="{Binding PlansCount}" Width="110"/>
                <DataGridTextColumn Header="Планов со скрытыми" Binding="{Binding PlansWithHiddenElementsCount}" Width="150"/>
                <DataGridTextColumn Header="Скрытий" Binding="{Binding HiddenOccurrencesCount}" Width="110"/>
                <DataGridTextColumn Header="Уникальных элементов" Binding="{Binding HiddenUniqueElementsCount}" Width="170"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="SaveReportButton"
                Content="Сохранить отчёт"
                Width="170"
                Height="30"
                Click="SaveReport_Click"/>

            <CheckBox x:Name="UnhideAllElementsCheckBox"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Content="Сделать видимыми все скрытые элементы"
                      IsChecked="False"/>

            <Button Grid.Column="4"
                    Content="Применить"
                    Width="120"
                    Height="30"
                    Click="Apply_Click"/>

            <Button Grid.Column="6"
                    Content="Отмена"
                    Width="100"
                    Height="30"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>