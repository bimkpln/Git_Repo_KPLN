<Window x:Class="KPLN_ViewsAndLists_Ribbon.Forms.FrmIZMFilling"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KPLN_ViewsAndLists_Ribbon.Forms"
        mc:Ignorable="d"
        Title="Заполнение ИЗМов"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:SheetTreeNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsThreeState="True"
                          IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </HierarchicalDataTemplate>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: дерево листов -->
            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Листы"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TreeView ItemsSource="{Binding RootNodes}"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Правая панель: таблица -->
            <Border Grid.Column="2"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Изменения по выбранным листам"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SheetRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="8"
                                            BorderBrush="DarkGray"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold"
                                                       FontSize="14"
                                                       Margin="0,0,0,4"
                                                       Text="{Binding SheetNumber}" />
                                            <TextBlock Margin="0,0,0,8"
                                                       Text="{Binding SheetName}" />

                                            <!-- Шапка -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="55"/>
                                                    <ColumnDefinition Width="300"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="№" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="Изм" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="Кол. уч." HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="Лист" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="№ док." HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="Подпись" HorizontalAlignment="Center"/>
                                                </Border>
                                                <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="1" Background="#FFEFEFEF" Padding="4">
                                                    <TextBlock Text="Дата" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>

                                            <!-- Строки -->
                                            <ItemsControl ItemsSource="{Binding Lines}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="300"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="180"/>
                                                                <ColumnDefinition Width="180"/>
                                                                <ColumnDefinition Width="120"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- № -->
                                                            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="4">
                                                                <TextBlock Text="{Binding DisplayNumber}" HorizontalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Изм -->
                                                            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="2">
                                                                <ComboBox ItemsSource="{Binding AvailableRevisionItems}"
                                                                          DisplayMemberPath="Name"
                                                                          SelectedItem="{Binding SelectedRevisionItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                    <ComboBox.ItemContainerStyle>
                                                                        <Style TargetType="ComboBoxItem">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                                    <Setter Property="Foreground" Value="Gray"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ComboBox.ItemContainerStyle>
                                                                </ComboBox>
                                                            </Border>

                                                            <!-- Кол. уч. -->
                                                            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="2">
                                                                <TextBox Text="{Binding QuantityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         HorizontalContentAlignment="Center"/>
                                                            </Border>

                                                            <!-- Лист -->
                                                            <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Padding="2">
                                                                <ComboBox ItemsSource="{Binding DataContext.StatusItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Name"
                                                                          SelectedValuePath="Code"
                                                                          SelectedValue="{Binding StatusCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            </Border>

                                                            <!-- № док. -->
                                                            <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Padding="4">
                                                                <TextBlock Text="{Binding RevisionDocNumber}" HorizontalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Подпись -->
                                                            <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="1" Padding="2">
                                                                <TextBox Text="{Binding SignatureText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         IsEnabled="{Binding HasRevisionSelected}"/>
                                                            </Border>

                                                            <!-- Дата -->
                                                            <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="1" Padding="4">
                                                                <TextBlock Text="{Binding RevisionDate}" HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Кнопки -->
        <DockPanel Grid.Row="1" Margin="0,12,0,0">
            <Button Content="Применить"
                    Width="140"
                    Height="34"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"
                    Click="BtnApply_Click"/>
        </DockPanel>
    </Grid>
</Window>