<Window x:Class="KPLN_ViewsAndLists_Ribbon.Forms.RevisionCloudSheetSelectionForm"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPLN. Изменения и Пометочные облака"
        Width="660"
        Height="720"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <HierarchicalDataTemplate x:Key="RevisionCloudSheetNodeTemplate"
                                  ItemsSource="{Binding Children}">
            <CheckBox Padding="1"
                      VerticalContentAlignment="Center"
                      IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsThreeState="False"
                      Content="{Binding DisplayName}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="Выберите листы для обработки" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#666666"
                       TextWrapping="Wrap"
                       Text="Структура соответствует текущей организации листов в Диспетчере проекта." />
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,14,0,8">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Width="110"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Click="SelectAll_Click"
                        Content="Выбрать всё" />
                <Button Width="130"
                        Padding="8,4"
                        Click="ClearSelection_Click"
                        Content="Снять выделение" />
            </StackPanel>
            <TextBlock x:Name="SelectionSummaryText"
                       Margin="12,0,2,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#666666" />
        </DockPanel>

        <Border Grid.Row="2"
                BorderBrush="#B8B8B8"
                BorderThickness="1"
                CornerRadius="2">
            <TreeView x:Name="SheetsTree"
                      Padding="6"
                      ItemTemplate="{StaticResource RevisionCloudSheetNodeTemplate}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="{x:Type TreeViewItem}">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <StackPanel Grid.Row="3"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="100"
                    Margin="0,0,8,0"
                    Padding="8,5"
                    IsCancel="True"
                    Content="Отмена" />
            <Button Width="100"
                    Padding="8,5"
                    IsDefault="True"
                    Click="Ok_Click"
                    Content="Обработать" />
        </StackPanel>
    </Grid>
</Window>
