<Window  
    x:Class="KPLN_ModelChecker_Lib.Forms.WorksetsForm"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="KPLN: Очистка пустых рабочих наборов" 
    Height="480" 
    Width="720"
    WindowStartupLocation="CenterOwner" 
    ResizeMode="CanResize"
    MinWidth="600" 
    MinHeight="360">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <StackPanel 
            Orientation="Horizontal" 
            Margin="0,0,0,8">
            <TextBlock 
                Text="Документ: " 
                FontWeight="Bold"/>
            <TextBlock 
                Text="{Binding DocumentTitle}" />
        </StackPanel>

        <!-- Таблица -->
        <DataGrid 
            Grid.Row="1"
            ItemsSource="{Binding WSColl}"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="False"
            HeadersVisibility="Column"
            BeginningEdit="WorksetsGrid_BeginningEdit">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridCell_PreviewMouseLeftButtonDown"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Удалить?" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox
                                IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn 
                    Binding="{Binding RevitWS.Name}" 
                    Header="РН для удаления" 
                    IsReadOnly="True" 
                    Width="*"/>
                <DataGridTextColumn 
                    Binding="{Binding RevitWSElemsCount}" 
                    Header="Кол-во элем-в в РН" 
                    IsReadOnly="True" 
                    Width="150"/>
                <DataGridTemplateColumn 
                    Header="РН на замену" 
                    Width="*"
                    SortMemberPath="SelectedReplacementWS.Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding SelectedReplacementWS.Name}"
                                VerticalAlignment="Center"
                                Margin="2,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="ToolTip" Value="Дважды кликните для выбора РН на замену"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RevitWSElemsCount}" Value="0">
                                                <Setter Property="ToolTip" Value="РН пустой — замена не требуется"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox
                                ItemsSource="{Binding ReplacementWorksets}"
                                SelectedItem="{Binding SelectedReplacementWS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberPath="Name"
                                IsDropDownOpen="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel 
            Grid.Row="2" 
            Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            Margin="0,8,0,0">
            <Button 
                Content="Удалить выбранные" 
                MinWidth="160" 
                Click="DeleteSelected_Click"/>
        </StackPanel>
    </Grid>
</Window>