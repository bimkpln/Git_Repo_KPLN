<UserControl 
    x:Class="KPLN_BIMTools_Ribbon.Forms.IFCExtraSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d" 
    Background="#FF292D36">

    <UserControl.Resources>
        <Style x:Key="TBlock" TargetType="TextBlock">
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TBlockTooltip" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="CBox" TargetType="CheckBox">
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CombBox" TargetType="ComboBox">
            <Setter Property="Width" Value="140"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="385"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Версия IFC"/>

                <ComboBox
                    x:Name="FileVersionComboBox"
                    Grid.Column="1"
                    Style="{StaticResource CombBox}"
                    SelectionChanged="FileVersion_Selected"/>
            </Grid>
        </Border>

        <Border Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Уровень границ пространств"/>

                <TextBox
                    Grid.Column="1"
                    Style="{StaticResource TBox}"
                    Width="50"
                    TextChanged="SpaceBoundaryLevel_TextChanged"
                    Text="{Binding SpaceBoundaryLevel, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Делить стены и колонны по уровням"/>

                <CheckBox
                    Grid.Column="1"
                    Style="{StaticResource CBox}"
                    IsChecked="{Binding WallAndColumnSplitting, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Экспортировать базовые количества"/>

                <CheckBox
                    Grid.Column="1"
                    Style="{StaticResource CBox}"
                    IsChecked="{Binding ExportBaseQuantities, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Экспортировать связанные файлы"/>

                <CheckBox
                    Grid.Column="1"
                    Style="{StaticResource CBox}"
                    IsChecked="{Binding ExportLinks, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Имя 3D-вида для экспорта"/>

                <TextBox
                    Grid.Column="1"
                    Style="{StaticResource TBox}"
                    Width="140"
                    Text="{Binding ViewName, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Border Grid.Row="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Имя рабочих наборов, которые нужно закрыть"/>

                <TextBox
                    Grid.Column="1"
                    Style="{StaticResource TBox}"
                    Width="140"
                    Text="{Binding WorksetToCloseNamesStartWith, UpdateSourceTrigger=PropertyChanged}">

                    <TextBox.ToolTip>
                        <StackPanel MaxWidth="700">
                            <TextBlock Style="{StaticResource TBlockTooltip}">
                                <Bold>Правила такие же, как в NWC:</Bold>
                            </TextBlock>
                            <TextBlock Style="{StaticResource TBlockTooltip}">1. Разделитель между разными РН - тильда "~"</TextBlock>
                            <TextBlock Style="{StaticResource TBlockTooltip}">2. По умолчанию правило "Начинается с"</TextBlock>
                            <TextBlock Style="{StaticResource TBlockTooltip}">3. *abc* - содержит</TextBlock>
                            <TextBlock Style="{StaticResource TBlockTooltip}">4. !abc! - НЕ содержит</TextBlock>
                        </StackPanel>
                    </TextBox.ToolTip>
                </TextBox>
            </Grid>
        </Border>

        <Border Grid.Row="7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Style="{StaticResource TBlock}"
                    Text="Спец. окончание в имени файла IFC"/>

                <TextBox
                    Grid.Column="1"
                    Style="{StaticResource TBox}"
                    Width="140"
                    ToolTip="Добавляется в конце имени получаемого файла IFC. Разделитель нужно указывать самостоятельно"
                    Text="{Binding IfcDocPostfix, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>