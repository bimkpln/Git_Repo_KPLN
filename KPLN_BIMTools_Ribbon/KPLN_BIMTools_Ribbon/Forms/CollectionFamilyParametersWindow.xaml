<Window x:Class="KPLN_BIMTools_Ribbon.Forms.CollectionFamilyParametersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="700"
        Width="1550"
        MinHeight="480"
        MinWidth="1050"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SelectableCellTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="24" />
        </Style>

        <Style x:Key="ParameterDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FF111111" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF3F3F3" />
                    <Setter Property="BorderBrush" Value="#FF6A6A6A" />
                    <Setter Property="Foreground" Value="#FF111111" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FF333333" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ParameterIdCellTemplate">
            <TextBox Text="{Binding ParameterIdText, Mode=OneWay}"
                     Style="{StaticResource SelectableCellTextBoxStyle}" />
        </DataTemplate>

        <DataTemplate x:Key="NameCellTemplate">
            <TextBox Text="{Binding Name, Mode=OneWay}"
                     Style="{StaticResource SelectableCellTextBoxStyle}" />
        </DataTemplate>

        <DataTemplate x:Key="GuidCellTemplate">
            <TextBox Text="{Binding Guid, Mode=OneWay}"
                     Style="{StaticResource SelectableCellTextBoxStyle}" />
        </DataTemplate>

        <DataTemplate x:Key="ReferenceItemsCellTemplate">
            <Border Padding="5,3">
                <ItemsControl ItemsSource="{Binding}"
                              Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap"
                                       Margin="0,1,0,1">
                                <Run Text="{Binding Text, Mode=OneWay}"
                                     Foreground="{Binding Foreground, Mode=OneWay}"/><Run Text="{Binding Separator, Mode=OneWay}"
                                     Foreground="{Binding Foreground, Mode=OneWay}"/><Run Text="{Binding Target, Mode=OneWay}"
                                     Foreground="{Binding Foreground, Mode=OneWay}"
                                     FontWeight="Bold"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FormulaCellTemplate">
            <TextBox Text="{Binding Formula, Mode=OneWay}"
                     Style="{StaticResource SelectableCellTextBoxStyle}"
                     Foreground="Black" />
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Description}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />

            <Button Grid.Column="1"
                    Content="Выгрузить в Excel"
                    MinWidth="130"
                    Margin="12,0,0,0"
                    Padding="10,4"
                    Click="ExportExcelButton_Click" />
        </Grid>

        <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}" />
            </StatusBarItem>
        </StatusBar>

        <DataGrid x:Name="ParametersGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  ClipboardCopyMode="ExcludeHeader"
                  CellStyle="{StaticResource ParameterDataGridCellStyle}"
                  PreviewKeyDown="ParametersGrid_PreviewKeyDown">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ID"
                                        Width="90"
                                        SortMemberPath="ParameterIdText"
                                        CellTemplate="{StaticResource ParameterIdCellTemplate}" />

                <DataGridTemplateColumn Header="Имя"
                                        Width="220"
                                        SortMemberPath="Name"
                                        CellTemplate="{StaticResource NameCellTemplate}" />

                <DataGridTemplateColumn Header="GUID"
                                        Width="260"
                                        SortMemberPath="Guid"
                                        CellTemplate="{StaticResource GuidCellTemplate}" />

                <DataGridTemplateColumn Header="Привязка параметра к вложенным семействам"
                                        Width="1.35*"
                                        MinWidth="330"
                                        SortMemberPath="NestedFamilyBindingsPlainText">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding NestedFamilyBindings, Mode=OneWay}"
                                            ContentTemplate="{StaticResource ReferenceItemsCellTemplate}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Участие формулы в других параметрах"
                                        Width="1.35*"
                                        MinWidth="330"
                                        SortMemberPath="CurrentFamilyFormulaUsagePlainText">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding CurrentFamilyFormulaUsage, Mode=OneWay}"
                                            ContentTemplate="{StaticResource ReferenceItemsCellTemplate}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Формула"
                                        Width="1*"
                                        MinWidth="260"
                                        SortMemberPath="Formula"
                                        CellTemplate="{StaticResource FormulaCellTemplate}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
